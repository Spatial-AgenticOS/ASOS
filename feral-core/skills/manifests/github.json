{
    "skill_id": "github_api",
    "version": "1.0.0",
    "author": "feral-core",
    "brand": {
        "name": "GitHub",
        "primary_color": "#238636",
        "secondary_color": "#161B22",
        "logo_url": "https://github.githubassets.com/favicons/favicon-dark.png",
        "icon_set": "sf_symbols"
    },
    "description": "Interact with GitHub repositories: view repos, issues, pull requests, and user profiles.",
    "trigger_phrases": [
        "my github repos",
        "show my repositories",
        "github issues",
        "open pull requests",
        "github notifications",
        "create an issue",
        "star a repo",
        "github profile"
    ],
    "categories": ["developer", "productivity", "code"],
    "auth": {
        "type": "bearer",
        "api_key_header": null,
        "authorize_url": null,
        "token_url": null,
        "scopes": ["repo", "user", "notifications"]
    },
    "endpoints": [
        {
            "id": "list_repos",
            "method": "GET",
            "url": "https://api.github.com/user/repos",
            "description": "List the authenticated user's repositories. Returns repo name, description, stars, language, and last updated.",
            "params": [
                {"name": "sort", "type": "string", "required": false, "default": "updated", "description": "Sort by: created, updated, pushed, full_name", "enum": ["created", "updated", "pushed", "full_name"]},
                {"name": "per_page", "type": "number", "required": false, "default": "10", "description": "Number of repos to return"}
            ],
            "returns_description": "Array of {name, full_name, description, stargazers_count, language, updated_at, html_url}",
            "ui_hint": "list"
        },
        {
            "id": "list_issues",
            "method": "GET",
            "url": "https://api.github.com/repos/{owner}/{repo}/issues",
            "description": "List issues for a specific repository. Returns issue title, state, labels, and author.",
            "params": [
                {"name": "owner", "type": "string", "required": true, "description": "Repository owner username"},
                {"name": "repo", "type": "string", "required": true, "description": "Repository name"},
                {"name": "state", "type": "string", "required": false, "default": "open", "description": "Filter by state", "enum": ["open", "closed", "all"]}
            ],
            "returns_description": "Array of {title, number, state, labels, user, created_at, body}",
            "ui_hint": "list"
        },
        {
            "id": "list_pull_requests",
            "method": "GET",
            "url": "https://api.github.com/repos/{owner}/{repo}/pulls",
            "description": "List pull requests for a repository. Returns PR title, state, author, and review status.",
            "params": [
                {"name": "owner", "type": "string", "required": true, "description": "Repository owner"},
                {"name": "repo", "type": "string", "required": true, "description": "Repository name"},
                {"name": "state", "type": "string", "required": false, "default": "open", "description": "Filter by state", "enum": ["open", "closed", "all"]}
            ],
            "returns_description": "Array of {title, number, state, user, created_at, head, base}",
            "ui_hint": "list"
        },
        {
            "id": "create_issue",
            "method": "POST",
            "url": "https://api.github.com/repos/{owner}/{repo}/issues",
            "description": "Create a new issue in a repository.",
            "params": [
                {"name": "owner", "type": "string", "required": true, "description": "Repository owner"},
                {"name": "repo", "type": "string", "required": true, "description": "Repository name"},
                {"name": "title", "type": "string", "required": true, "description": "Issue title"},
                {"name": "body", "type": "string", "required": false, "description": "Issue body/description"}
            ],
            "returns_description": "{number, title, html_url, state}",
            "ui_hint": "detail_card"
        },
        {
            "id": "user_profile",
            "method": "GET",
            "url": "https://api.github.com/user",
            "description": "Get the authenticated user's GitHub profile info.",
            "params": [],
            "returns_description": "{login, name, avatar_url, bio, public_repos, followers, following}",
            "ui_hint": "detail_card"
        },
        {
            "id": "notifications",
            "method": "GET",
            "url": "https://api.github.com/notifications",
            "description": "Get the user's GitHub notifications.",
            "params": [
                {"name": "all", "type": "boolean", "required": false, "default": "false", "description": "Show all notifications including read"}
            ],
            "returns_description": "Array of {subject, reason, updated_at, repository}",
            "ui_hint": "list"
        }
    ],
    "flows": [],
    "crons": [],
    "triggers": [],
    "permissions": [],
    "requires_daemon": false,
    "max_calls_per_hour": 5000
}
