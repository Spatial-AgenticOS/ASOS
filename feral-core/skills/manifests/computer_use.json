{
    "skill_id": "computer_use",
    "version": "1.0.0",
    "author": "feral-core",
    "brand": {
        "name": "Computer Use",
        "primary_color": "#6c5ce7",
        "secondary_color": "#2d3436",
        "logo_url": "",
        "icon_set": "sf_symbols"
    },
    "description": "Execute shell commands, read/write/edit files, search codebases, and fetch web content. The core tools that make FERAL a real coding agent.",
    "trigger_phrases": [
        "run", "execute", "bash", "shell", "command",
        "read file", "show file", "cat",
        "write file", "create file", "save file",
        "edit file", "replace", "change in file",
        "search", "grep", "find in code",
        "find files", "list files", "glob",
        "fetch", "download", "curl", "get url"
    ],
    "categories": ["system", "development", "utility"],
    "auth": {
        "type": "none"
    },
    "endpoints": [
        {
            "id": "bash",
            "method": "PYTHON",
            "url": "",
            "description": "Execute a shell command and return stdout/stderr. Use for running programs, git, npm, pip, etc.",
            "params": [
                {"name": "command", "type": "string", "required": true, "description": "The shell command to execute"},
                {"name": "timeout", "type": "integer", "required": false, "description": "Timeout in seconds (default 30)"}
            ],
            "returns_description": "stdout, stderr, and exit code",
            "ui_hint": "detail_card"
        },
        {
            "id": "read_file",
            "method": "PYTHON",
            "url": "",
            "description": "Read the contents of a file. Returns the text content with line numbers.",
            "params": [
                {"name": "path", "type": "string", "required": true, "description": "Absolute or relative file path"},
                {"name": "offset", "type": "integer", "required": false, "description": "Start reading from this line (1-based)"},
                {"name": "limit", "type": "integer", "required": false, "description": "Maximum number of lines to read"}
            ],
            "returns_description": "File contents with line numbers",
            "ui_hint": "detail_card"
        },
        {
            "id": "write_file",
            "method": "PYTHON",
            "url": "",
            "description": "Create or overwrite a file with the given content.",
            "params": [
                {"name": "path", "type": "string", "required": true, "description": "File path to write to"},
                {"name": "content", "type": "string", "required": true, "description": "The content to write"}
            ],
            "returns_description": "Confirmation of file creation with byte count",
            "ui_hint": "detail_card"
        },
        {
            "id": "edit_file",
            "method": "PYTHON",
            "url": "",
            "description": "Search and replace text in a file. Finds the first occurrence of old_text and replaces it with new_text.",
            "params": [
                {"name": "path", "type": "string", "required": true, "description": "File path to edit"},
                {"name": "old_text", "type": "string", "required": true, "description": "Exact text to find (must be unique in file)"},
                {"name": "new_text", "type": "string", "required": true, "description": "Replacement text"}
            ],
            "returns_description": "Confirmation with diff preview",
            "ui_hint": "detail_card"
        },
        {
            "id": "grep_search",
            "method": "PYTHON",
            "url": "",
            "description": "Search for a regex pattern in files. Like ripgrep — finds matching lines in a directory.",
            "params": [
                {"name": "pattern", "type": "string", "required": true, "description": "Regex pattern to search for"},
                {"name": "path", "type": "string", "required": false, "description": "Directory or file to search in (default: current directory)"},
                {"name": "include", "type": "string", "required": false, "description": "File glob pattern to include (e.g. '*.py')"}
            ],
            "returns_description": "Matching lines with file paths and line numbers",
            "ui_hint": "list"
        },
        {
            "id": "glob_search",
            "method": "PYTHON",
            "url": "",
            "description": "Find files matching a glob pattern. Useful for discovering project structure.",
            "params": [
                {"name": "pattern", "type": "string", "required": true, "description": "Glob pattern (e.g. '**/*.py', 'src/**/*.ts')"},
                {"name": "path", "type": "string", "required": false, "description": "Root directory to search from (default: current directory)"}
            ],
            "returns_description": "List of matching file paths",
            "ui_hint": "list"
        },
        {
            "id": "web_fetch",
            "method": "PYTHON",
            "url": "",
            "description": "Fetch a URL and return its content as readable text (HTML stripped).",
            "params": [
                {"name": "url", "type": "string", "required": true, "description": "The URL to fetch"},
                {"name": "max_length", "type": "integer", "required": false, "description": "Max characters to return (default 10000)"}
            ],
            "returns_description": "Page content as plain text",
            "ui_hint": "detail_card"
        }
    ],
    "flows": [],
    "crons": [],
    "triggers": [],
    "permissions": ["filesystem", "network", "shell"],
    "requires_daemon": false,
    "max_calls_per_hour": 10000
}
