{
    "skill_id": "messaging",
    "version": "2.0.0",
    "author": "feral-core",
    "brand": {
        "name": "Messaging",
        "primary_color": "#00B894",
        "secondary_color": "#0984E3",
        "logo_url": "",
        "icon_set": "sf_symbols"
    },
    "description": "Send messages on any connected channel: Telegram, Slack, Discord, WhatsApp, or SMS (Twilio). Use messaging.send for all proactive outreach; use list_chats to discover known Telegram chats.",
    "trigger_phrases": [
        "send a text",
        "text someone",
        "send a message",
        "message",
        "telegram",
        "slack",
        "discord",
        "whatsapp",
        "sms",
        "notify",
        "tell them"
    ],
    "categories": ["messaging", "communication"],
    "auth": {
        "type": "none"
    },
    "endpoints": [
        {
            "id": "send",
            "method": "PYTHON",
            "url": "internal://messaging/send",
            "description": "Send a message on a specific channel (telegram, slack, discord, whatsapp, sms). Target is chat_id, channel id, phone E.164, or @username for Telegram if the user has messaged the bot before.",
            "params": [
                {
                    "name": "channel",
                    "type": "string",
                    "required": true,
                    "description": "telegram | slack | discord | whatsapp | sms",
                    "enum": ["telegram", "slack", "discord", "whatsapp", "sms"]
                },
                {
                    "name": "target",
                    "type": "string",
                    "required": true,
                    "description": "chat_id, slack channel id, discord channel id, whatsapp id, E.164 phone, or @username (Telegram, if known)"
                },
                {
                    "name": "text",
                    "type": "string",
                    "required": true,
                    "description": "Message body"
                },
                {
                    "name": "reply_to",
                    "type": "string",
                    "required": false,
                    "description": "Optional thread/message id for threading (platform-specific)"
                }
            ],
            "returns_description": "{success, data, error}",
            "ui_hint": "detail_card"
        },
        {
            "id": "broadcast",
            "method": "PYTHON",
            "url": "internal://messaging/broadcast",
            "description": "Send the same text to every chat the bot has seen on that channel (best-effort).",
            "params": [
                {
                    "name": "channel",
                    "type": "string",
                    "required": true,
                    "description": "telegram | slack | discord | whatsapp",
                    "enum": ["telegram", "slack", "discord", "whatsapp"]
                },
                {
                    "name": "text",
                    "type": "string",
                    "required": true,
                    "description": "Message body"
                }
            ],
            "returns_description": "{success, data, error}",
            "ui_hint": "detail_card"
        },
        {
            "id": "list_chats",
            "method": "PYTHON",
            "url": "internal://messaging/list_chats",
            "description": "List known chats (Telegram: from stored contacts + active session). For Discord Slack list APIs, pass guild_id when required.",
            "params": [
                {
                    "name": "channel",
                    "type": "string",
                    "required": true,
                    "description": "telegram | slack | discord | whatsapp | sms",
                    "enum": ["telegram", "slack", "discord", "whatsapp", "sms"]
                },
                {
                    "name": "guild_id",
                    "type": "string",
                    "required": false,
                    "description": "Discord guild id for discord list_channels"
                }
            ],
            "returns_description": "{chats: [...]}",
            "ui_hint": "list"
        }
    ],
    "flows": [],
    "crons": [],
    "triggers": [],
    "permissions": ["messaging"],
    "requires_daemon": false,
    "max_calls_per_hour": 200
}
