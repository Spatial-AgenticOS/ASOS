{
    "skill_id": "desktop_control",
    "version": "1.2.0",
    "author": "feral-core",
    "brand": {
        "name": "Desktop Control",
        "primary_color": "#A855F7",
        "secondary_color": "#6D28D9",
        "logo_url": "",
        "icon_set": "sf_symbols"
    },
    "description": "Control the local computer: open any app, create/read/write files, run shell commands, take screenshots, adjust volume, and get system info. Always available on the user's machine.",
    "trigger_phrases": [
        "open chrome",
        "open safari",
        "open music",
        "open spotify",
        "open terminal",
        "open vscode",
        "open finder",
        "open notes",
        "open an app",
        "open application",
        "launch app",
        "start app",
        "lock my mac",
        "take a screenshot",
        "run a script",
        "run a command",
        "adjust volume",
        "mute",
        "turn up the volume",
        "set volume",
        "dark mode",
        "what apps are running",
        "close this app",
        "create a file",
        "create a note on my desktop",
        "write a file",
        "make a file",
        "save a file",
        "create a text file",
        "write to desktop",
        "create note on desktop",
        "write hello",
        "system info",
        "cpu usage",
        "disk space",
        "battery level",
        "how much storage"
    ],
    "categories": ["system", "desktop", "hardware"],
    "auth": {
        "type": "none"
    },
    "endpoints": [
        {
            "id": "open_app",
            "method": "POST",
            "url": "daemon://local/applescript",
            "description": "Open ANY application on the user's Mac using AppleScript. Use this whenever the user asks to open, launch, or start an app (Music, Safari, Chrome, Spotify, Notes, Terminal, Finder, etc.). The script parameter should be AppleScript like: tell application \"AppName\" to activate",
            "params": [
                {"name": "script", "type": "string", "required": true, "description": "AppleScript to execute. MUST use format: tell application \"AppName\" to activate. Examples: tell application \"Music\" to activate, tell application \"Safari\" to activate, tell application \"Notes\" to activate"}
            ],
            "returns_description": "{output, exit_code}",
            "ui_hint": null
        },
        {
            "id": "shell_command",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Run any shell command on the user's Mac. Use for: creating files (echo/cat/touch), reading files, listing directories, volume control, screenshots, system tasks. When user says 'create a note/file on my desktop', use: echo 'content' > ~/Desktop/filename.txt",
            "params": [
                {"name": "command", "type": "string", "required": true, "description": "Shell command to execute. Examples: echo 'hello' > ~/Desktop/note.txt, ls ~/Desktop, cat ~/Desktop/file.txt, screencapture -x /tmp/screenshot.png"},
                {"name": "timeout_seconds", "type": "number", "required": false, "default": "10", "description": "Max execution time"}
            ],
            "returns_description": "{output, exit_code}",
            "ui_hint": null
        },
        {
            "id": "screenshot",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Capture a screenshot of the user's screen.",
            "params": [
                {"name": "command", "type": "string", "required": false, "default": "screencapture -x /tmp/feral_screenshot.png && echo 'Screenshot saved to /tmp/feral_screenshot.png'", "description": "Screenshot command"}
            ],
            "returns_description": "{output, exit_code}",
            "ui_hint": null
        },
        {
            "id": "system_info",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Get system information: CPU usage, memory, disk space, battery level.",
            "params": [
                {"name": "command", "type": "string", "required": false, "default": "echo '{\"cpu\":\"'$(top -l 1 | grep 'CPU usage' | awk '{print $3}')'\"}'", "description": "System info command"}
            ],
            "returns_description": "{cpu_usage, memory_used, disk_free, battery_percent}",
            "ui_hint": "metric"
        },
        {
            "id": "set_volume",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Set the system volume level on the Mac.",
            "params": [
                {"name": "command", "type": "string", "required": true, "description": "osascript command for volume. Example: osascript -e 'set volume output volume 50'"}
            ],
            "returns_description": "{output, exit_code}",
            "ui_hint": null
        }
    ],
    "flows": [
        {
            "id": "lock_screen",
            "description": "Lock the Mac screen immediately",
            "steps": [
                {"endpoint_id": "shell_command"}
            ]
        }
    ],
    "crons": [],
    "triggers": [],
    "permissions": ["system", "shell"],
    "requires_daemon": false,
    "daemon_node_type": "desktop",
    "max_calls_per_hour": 500
}
