{
    "skill_id": "desktop_control",
    "version": "1.0.0",
    "author": "theora-core",
    "brand": {
        "name": "Desktop Control",
        "primary_color": "#A855F7",
        "secondary_color": "#6D28D9",
        "logo_url": "",
        "icon_set": "sf_symbols"
    },
    "description": "Control your desktop computer: open apps, run scripts, manage windows, lock screen, take screenshots, and execute shell commands. Requires a connected THEORA daemon.",
    "trigger_phrases": [
        "open chrome",
        "open safari",
        "lock my mac",
        "take a screenshot",
        "open terminal",
        "run a script",
        "open vscode",
        "open file manager",
        "adjust volume",
        "mute",
        "turn up the volume",
        "dark mode",
        "what apps are running",
        "close this app",
        "open spotify"
    ],
    "categories": ["system", "desktop", "hardware"],
    "auth": {
        "type": "none"
    },
    "endpoints": [
        {
            "id": "open_app",
            "method": "POST",
            "url": "daemon://local/applescript",
            "description": "Open an application on the user's Mac. Specify the app name.",
            "params": [
                {"name": "script", "type": "string", "required": true, "description": "AppleScript to execute. Example: tell application \"Safari\" to activate"}
            ],
            "returns_description": "{status, stdout, stderr}",
            "ui_hint": null
        },
        {
            "id": "shell_command",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Run a shell command on the user's machine. Use for system tasks like volume control, screenshots, etc.",
            "params": [
                {"name": "command", "type": "string", "required": true, "description": "Shell command to execute"},
                {"name": "timeout_seconds", "type": "number", "required": false, "default": "10", "description": "Max execution time"}
            ],
            "returns_description": "{status, exit_code, stdout, stderr}",
            "ui_hint": null
        },
        {
            "id": "screenshot",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Capture a screenshot of the user's screen.",
            "params": [
                {"name": "command", "type": "string", "required": false, "default": "screencapture -x /tmp/theora_screenshot.png", "description": "Screenshot command"}
            ],
            "returns_description": "{status, file_path}",
            "ui_hint": null
        },
        {
            "id": "system_info",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Get system information: CPU usage, memory, disk space, battery level.",
            "params": [
                {"name": "command", "type": "string", "required": false, "default": "echo '{\"cpu\":\"'$(top -l 1 | grep 'CPU usage' | awk '{print $3}')'\"}'", "description": "System info command"}
            ],
            "returns_description": "{cpu_usage, memory_used, disk_free, battery_percent}",
            "ui_hint": "metric"
        },
        {
            "id": "set_volume",
            "method": "POST",
            "url": "daemon://local/shell",
            "description": "Set the system volume level on the Mac.",
            "params": [
                {"name": "command", "type": "string", "required": true, "description": "osascript command for volume. Example: osascript -e 'set volume output volume 50'"}
            ],
            "returns_description": "{status}",
            "ui_hint": null
        }
    ],
    "flows": [
        {
            "id": "lock_screen",
            "description": "Lock the Mac screen immediately",
            "steps": [
                {"endpoint_id": "shell_command"}
            ]
        }
    ],
    "crons": [],
    "triggers": [],
    "permissions": ["system", "shell"],
    "requires_daemon": true,
    "daemon_node_type": "desktop",
    "max_calls_per_hour": 500
}
