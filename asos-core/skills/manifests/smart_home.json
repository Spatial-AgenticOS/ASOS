{
    "skill_id": "smart_home_hue",
    "version": "1.0.0",
    "author": "theora-core",
    "brand": {
        "name": "Smart Home",
        "primary_color": "#F5A623",
        "secondary_color": "#1A1A2E",
        "logo_url": "",
        "icon_set": "sf_symbols"
    },
    "description": "Control Philips Hue smart lights: turn on/off, change colors, adjust brightness, set scenes.",
    "trigger_phrases": [
        "turn on the lights",
        "turn off the lights",
        "dim the lights",
        "change light color",
        "set lights to red",
        "lights to 50 percent",
        "make it brighter",
        "night mode",
        "set the mood",
        "living room lights"
    ],
    "categories": ["smart_home", "iot", "hardware"],
    "auth": {
        "type": "bearer"
    },
    "endpoints": [
        {
            "id": "list_lights",
            "method": "GET",
            "url": "http://localhost:8743/api/{username}/lights",
            "description": "List all connected Hue lights. Returns light name, state (on/off), brightness, color.",
            "params": [
                {"name": "username", "type": "string", "required": true, "description": "Hue Bridge API username"}
            ],
            "returns_description": "Object with light IDs as keys: {name, state: {on, bri, hue, sat}, type, modelid}",
            "ui_hint": "grid_cards"
        },
        {
            "id": "set_light_state",
            "method": "PUT",
            "url": "http://localhost:8743/api/{username}/lights/{light_id}/state",
            "description": "Set the state of a specific light. Control on/off, brightness, color, and effects.",
            "params": [
                {"name": "username", "type": "string", "required": true, "description": "Hue Bridge API username"},
                {"name": "light_id", "type": "string", "required": true, "description": "Light ID number"},
                {"name": "on", "type": "boolean", "required": false, "description": "Turn light on or off"},
                {"name": "bri", "type": "number", "required": false, "description": "Brightness (1-254)"},
                {"name": "hue", "type": "number", "required": false, "description": "Hue color value (0-65535)"},
                {"name": "sat", "type": "number", "required": false, "description": "Saturation (0-254)"},
                {"name": "effect", "type": "string", "required": false, "description": "Effect: none or colorloop", "enum": ["none", "colorloop"]}
            ],
            "returns_description": "Array of success/error responses",
            "ui_hint": null
        },
        {
            "id": "list_scenes",
            "method": "GET",
            "url": "http://localhost:8743/api/{username}/scenes",
            "description": "List all available Hue scenes.",
            "params": [
                {"name": "username", "type": "string", "required": true, "description": "Hue Bridge API username"}
            ],
            "returns_description": "Object with scene IDs: {name, type, lights, group}",
            "ui_hint": "list"
        },
        {
            "id": "set_group_state",
            "method": "PUT",
            "url": "http://localhost:8743/api/{username}/groups/{group_id}/action",
            "description": "Set state for a group of lights (e.g., all living room lights).",
            "params": [
                {"name": "username", "type": "string", "required": true, "description": "Hue Bridge API username"},
                {"name": "group_id", "type": "string", "required": true, "description": "Group ID (0 = all lights)"},
                {"name": "on", "type": "boolean", "required": false, "description": "Turn group on or off"},
                {"name": "bri", "type": "number", "required": false, "description": "Brightness (1-254)"},
                {"name": "scene", "type": "string", "required": false, "description": "Scene ID to activate"}
            ],
            "returns_description": "Array of success/error responses",
            "ui_hint": null
        }
    ],
    "flows": [
        {
            "id": "goodnight",
            "description": "Turn off all lights gradually over 30 seconds",
            "steps": [
                {"endpoint_id": "set_group_state", "condition": null}
            ]
        }
    ],
    "crons": [],
    "triggers": [
        {
            "id": "sleep_detected",
            "condition": "biometric.inferred_state == 'sleeping'",
            "action_flow_id": "goodnight",
            "cooldown_seconds": 3600
        }
    ],
    "permissions": ["smart_home"],
    "requires_daemon": false,
    "max_calls_per_hour": 500
}
