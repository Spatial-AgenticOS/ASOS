# ─── FERAL Brain Configuration ───

# Runtime Contract (shared across server/cli/client/desktop)
FERAL_HOME=~/.feral                 # config + credentials root
FERAL_HOST=127.0.0.1                   # bind host for uvicorn
FERAL_PORT=9090                      # bind port for uvicorn
FERAL_PUBLIC_BASE_URL=http://localhost:9090  # public browser/API base URL
FERAL_MARKETPLACE_URL=http://localhost:8080/api/v1
FERAL_OLLAMA_BASE_URL=http://localhost:11434

# LLM Provider
OPENAI_API_KEY=sk-your-key-here
FERAL_LLM_PROVIDER=openai          # openai | ollama | groq
FERAL_LLM_MODEL=gpt-4o-mini        # gpt-4o | gpt-4o-mini | llama3 | etc
FERAL_LLM_BASE_URL=                 # leave blank for defaults
GROQ_API_KEY=                        # only if using Groq

# Audio Pipeline
FERAL_STT_PROVIDER=openai           # openai (Whisper)
FERAL_STT_MODEL=whisper-1
FERAL_TTS_PROVIDER=openai
FERAL_TTS_MODEL=tts-1
FERAL_TTS_VOICE=nova                # alloy | echo | fable | onyx | nova | shimmer

# Vision Pipeline
FERAL_VISION_ENABLED=false
FERAL_VISION_MAX_FRAME_KB=512

# Proactive Agent
FERAL_PROACTIVE=false               # enable proactive behavior (health alerts, auto-actions)

# Streaming LLM
FERAL_STREAMING=true                # enable token-by-token streaming to client

# Scene Understanding
FERAL_SCENE_COOLDOWN=10             # seconds between VLM scene analyses per node

# Security
NODE_API_KEY=

# Skill API Keys (blind vault pattern — LLM never sees these)
# FERAL_KEY_web_search=tvly-xxxx    # Tavily API key
# FERAL_KEY_spotify_music=Bearer xxxx
# FERAL_KEY_messaging_sms=xxxx      # Twilio
# FERAL_KEY_calendar_google=xxxx
# FERAL_KEY_github_api=ghp_xxxx
