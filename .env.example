# ─── THEORA Brain Configuration ───

# LLM Provider
OPENAI_API_KEY=sk-your-key-here
THEORA_LLM_PROVIDER=openai          # openai | ollama | groq
THEORA_LLM_MODEL=gpt-4o-mini        # gpt-4o | gpt-4o-mini | llama3 | etc
THEORA_LLM_BASE_URL=                 # leave blank for defaults
GROQ_API_KEY=                        # only if using Groq

# Audio Pipeline
THEORA_STT_PROVIDER=openai           # openai (Whisper)
THEORA_STT_MODEL=whisper-1
THEORA_TTS_PROVIDER=openai
THEORA_TTS_MODEL=tts-1
THEORA_TTS_VOICE=nova                # alloy | echo | fable | onyx | nova | shimmer

# Vision Pipeline
THEORA_VISION_ENABLED=false
THEORA_VISION_MAX_FRAME_KB=512

# Proactive Agent
THEORA_PROACTIVE=false               # enable proactive behavior (health alerts, auto-actions)

# Streaming LLM
THEORA_STREAMING=true                # enable token-by-token streaming to client

# Scene Understanding
THEORA_SCENE_COOLDOWN=10             # seconds between VLM scene analyses per node

# Security
NODE_API_KEY=dev-secret-key

# Skill API Keys (blind vault pattern — LLM never sees these)
# THEORA_KEY_web_search=tvly-xxxx    # Tavily API key
# THEORA_KEY_spotify_music=Bearer xxxx
# THEORA_KEY_messaging_sms=xxxx      # Twilio
# THEORA_KEY_calendar_google=xxxx
# THEORA_KEY_github_api=ghp_xxxx
