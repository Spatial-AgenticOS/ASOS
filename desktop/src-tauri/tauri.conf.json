{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FERAL",
  "version": "1.0.0",
  "identifier": "ai.feral.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FERAL",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "id": "feral-tray",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "FERAL"
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' ws://localhost:* http://localhost:* ws://127.0.0.1:* http://127.0.0.1:*; img-src 'self' data: blob: http://localhost:* http://127.0.0.1:*; media-src 'self' blob:; font-src 'self' data:; frame-src 'self' http://localhost:* http://127.0.0.1:*",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "FERAL — Local-First AI Agent",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/feral-ai/feral-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
