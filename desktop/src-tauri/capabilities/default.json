{
  "identifier": "default",
  "description": "Main + floating window: brain control, tray, autostart, shortcuts, notifications",
  "windows": ["main", "floating"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible",
    "core:window:allow-close",
    "core:window:allow-center",
    "autostart:default"
  ]
}
